# Copy each line into Railway → Variables (Production backend service)
# Do NOT commit real secrets — this file is a checklist only.

NODE_ENV=production
HOST=0.0.0.0

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/nova-shop?retryWrites=true&w=majority&appName=Khareedo
MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4

JWT_SECRET=generate-with-crypto-randomBytes
JWT_EXPIRE=7d

ADMIN_EMAIL=your-admin@gmail.com
ADMIN_PASSWORD=your-strong-password
ADMIN_NAME=Store Admin

FRONTEND_URL=https://bazaar-pk.com,https://www.bazaar-pk.com,https://souvenirhandicraft.com,https://www.souvenirhandicraft.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# STRIPE_SECRET_KEY=sk_live_...   (must start with sk_live_, not mk_)
