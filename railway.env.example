# Copy each line into Railway → Variables (Production backend service)
# Do NOT commit real secrets — this file is a checklist only.

NODE_ENV=production
HOST=0.0.0.0

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/nova-shop?retryWrites=true&w=majority&appName=Khareedo
MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4

JWT_SECRET=generate-with-crypto-randomBytes
JWT_EXPIRE=7d

ADMIN_EMAIL=your-admin@gmail.com
ADMIN_PASSWORD=your-strong-password
ADMIN_NAME=Store Admin

FRONTEND_URL=https://www.bazaar-pk.com,https://bazaar-pk.com

# Optional: serve React build from this Express app (VPS / single-host deploy).
# FRONTEND_BUILD_PATH=/app/frontend/build

# Image upload optimization (Sharp → WebP before Cloudinary)
# IMAGE_MAX_WIDTH=1400
# IMAGE_MAX_BYTES=120000
# IMAGE_WEBP_QUALITY=82
# IMAGE_OPTIMIZE=false

# In-memory API cache (node-cache) — categories, settings, homepage promos
# CACHE_TTL_SECONDS=3600
# CACHE_ENABLED=true
# After direct DB scripts (allowlist), flush stale cache without redeploy:
# CACHE_FLUSH_SECRET=generate-a-long-random-string

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Order emails (REQUIRED on Railway — Gmail SMTP is blocked) ──
# 1. Sign up: https://resend.com (free tier)
# 2. Add domain bazaar-pk.com → verify DNS records in Resend dashboard
# 3. Create API key → paste below
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Bazaar <orders@bazaar-pk.com>

# Keep for reference / local dev only (SMTP does NOT work on Railway):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_USER=your-admin@gmail.com
# EMAIL_PASS=gmail-app-password

# Optional
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# AI SEO blog drafts (Hugging Face — free tier)
# Get token: https://huggingface.co/settings/tokens (Read access)
HUGGINGFACE_API_KEY=
# HUGGINGFACE_BLOG_MODEL=Qwen/Qwen2.5-7B-Instruct
# AI_BLOG_CRON_ENABLED=true
# AI_BLOG_CRON_INTERVAL_MS=86400000
# OPENAI_API_KEY=   (optional — chatbot / smart search only)

# WhatsApp live chat (Whapi.cloud) — messages to your WhatsApp 03483510584
# WHAPI_API_TOKEN=your_whapi_bearer_token
# WHAPI_ADMIN_CHAT_ID=923483510584@c.us
# WHATSAPP_SUPPORT_PHONE=923483510584
# Webhook URL (Whapi dashboard): https://YOUR-RAILWAY-DOMAIN/api/chat/whatsapp-webhook
