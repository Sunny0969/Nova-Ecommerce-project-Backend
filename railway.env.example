# Copy each line into Railway → Variables (Production backend service)
# Do NOT commit real secrets — this file is a checklist only.

NODE_ENV=production
HOST=0.0.0.0

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/nova-shop?retryWrites=true&w=majority&appName=Khareedo
MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4

JWT_SECRET=generate-with-crypto-randomBytes
JWT_EXPIRE=7d

ADMIN_EMAIL=your-admin@gmail.com
ADMIN_PASSWORD=your-strong-password
ADMIN_NAME=Store Admin

FRONTEND_URL=https://bazaar-pk.com,https://www.bazaar-pk.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Order emails (REQUIRED on Railway — Gmail SMTP is blocked) ──
# 1. Sign up: https://resend.com (free tier)
# 2. Add domain bazaar-pk.com → verify DNS records in Resend dashboard
# 3. Create API key → paste below
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Bazaar <orders@bazaar-pk.com>

# Keep for reference / local dev only (SMTP does NOT work on Railway):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_USER=your-admin@gmail.com
# EMAIL_PASS=gmail-app-password

# Optional
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
