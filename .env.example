PORT=5000
MONGODB_URI=
# Optional: if mongodb+srv fails with queryTxt/querySrv errors, try Google DNS (omit on locked-down networks)
# MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4
JWT_SECRET=
JWT_EXPIRE=7d
# Admin login (same /login as customers — user is created/updated on server start)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Store Admin
# Cloudinary (Media Library → API Keys / Dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
# Optional: model for query suggestions (defaults to gpt-4o-mini)
# OPENAI_SUGGEST_MODEL=gpt-4o-mini
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
# Your live site (Hostinger) — no trailing slash. Comma-separate for multiple: https://a.com,https://b.com
# On Render, set this to your real domain (e.g. https://ebadahgroup.com) so CORS + email links work.
# Local dev can stay http://localhost:3000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
